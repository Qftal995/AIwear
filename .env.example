# AIWear 3.0 环境变量配置
# 复制此文件为 .env 并填入真实值

# DeepSeek API (Agent 主流程 LLM)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 通义千问 API (视觉模型)
DASHSCOPE_API_KEY=sk-your-dashscope-key

# 阿里云 OSS 对象存储
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket

# 心知天气 API
XINZHI_WEATHER_KEY=your-weather-key
XINZHI_WEATHER_PUBLIC_KEY=your-weather-public-key

# RabbitMQ (Docker 内部通信)
RABBITMQ_HOST=bite_wear-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=aiwear
RABBITMQ_PASSWORD=aiwear@mq

# FAISS 索引路径 (Docker 内为 /data/faiss_index)
FAISS_INDEX_PATH=/data/faiss_index

# CLIP 模型路径 (可选，默认使用 huggingface 缓存)
# CLIP_MODEL_DIR=D:\Java仓\code\AIWear-master\代码\AIWearPython\openai-mirror\clip-vit-base-patch16

# RAG 知识库目录
RAG_KNOWLEDGE_DIR=D:\\obsidian\\笔记\\AiwearRag知识库

# AI Service 地址 (Java 后端调用 Python 用)
PYTHON_SERVICE_BASE_URL=http://127.0.0.1:5001
